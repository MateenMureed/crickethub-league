{
  "name": "crickethub-mobile",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "cap:init": "npx cap init CricketHub com.crickethub.app --web-dir dist",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "apk:debug": "npm run build ; npx cap sync android ; cd android ; gradlew.bat assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "html2canvas": "^1.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.3.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.2.2"
  }
}
