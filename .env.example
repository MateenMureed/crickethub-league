# Frontend: API base used by client-side fetch requests
# Keep as /api in local dev to use Vite proxy.
VITE_API_URL=/api

# Frontend dev server: backend target for Vite proxy.
VITE_BACKEND_URL=http://localhost:3001

# Backend server port
PORT=3001

# Backend CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Azure Cosmos DB (set in Azure App Service app settings)
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DB_NAME=league-db
COSMOS_CONTAINER_NAME=app-state
COSMOS_PARTITION_KEY=default
COSMOS_DOC_ID=state
